// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model SiteInfo {
  id             Int      @id @default(1)
  farmName       String   @default("행복한 농장")
  farmIntro      String   @default("신선하고 맛있는 농작물을 재배하는 행복한 농장입니다.")
  farmImage      String?
  introText      String   @default("온전한 쉼을 위한 공간, 여행")
  heroNotice     String   @default("운영시간: 매일 09:00 ~ 18:00")
  cartName       String   @default("쇼핑 카트")
  cabinIntro     String   @default("아늑하고 편안한 쉼터, 저희 농장의 농막을 소개합니다.")
  cabinImage     String?
  cabinImages    String   @default("[]")
  phoneNumber    String   @default("010-0000-0000")
  kakaoLink      String   @default("http://pf.kakao.com/...")
  address        String   @default("강원도 어딘가 멋진 농장")
  updatedAt      DateTime @updatedAt
}

model Crop {
  id          Int      @id @default(autoincrement())
  name        String
  description String
  price       String
  image       String?
  isAvailable Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ReservationItem ReservationItem[]
}

model Reservation {
  id           Int      @id @default(autoincrement())
  customerName String
  phoneNumber  String
  status       String   @default("대기") // 대기, 확인, 취소 등
  items        ReservationItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReservationItem {
  id            Int      @id @default(autoincrement())
  reservationId Int
  cropId        Int
  quantity      Int
  priceSnapshot String   @default("")
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  crop          Crop        @relation(fields: [cropId], references: [id], onDelete: Cascade)
}
